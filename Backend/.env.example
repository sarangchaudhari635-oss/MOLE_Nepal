# =============================================
# MOLE Backend — Environment Variables
# Copy this file to .env and fill in your values
# =============================================

# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- Supabase ----
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---- Gemini AI ----
# Get from: console.cloud.google.com → APIs → Gemini (free tier)
GEMINI_API_KEY=your-gemini-api-key

# ---- JWT Auth ----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-64-chars

# ---- CORS ----
# Frontend URL (Next.js dev server or Vercel URL)
FRONTEND_URL=http://localhost:3000

# ---- Map Defaults (Kathmandu) ----
MAP_CENTER_LAT=27.7172
MAP_CENTER_LNG=85.3240
